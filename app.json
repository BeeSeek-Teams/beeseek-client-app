{
  "expo": {
    "name": "BeeSeek Client",
    "slug": "BeeSeek-Client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "beeseekclient",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.beeseek.client",
      "googleServicesFile": "./GoogleService-Info.plist",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "BeeSeek needs access to your camera to take photos for your profile and support tickets.",
        "NSPhotoLibraryUsageDescription": "BeeSeek needs access to your photo library to upload images.",
        "NSMicrophoneUsageDescription": "BeeSeek needs access to your microphone to record voice messages.",
        "NSFaceIDUsageDescription": "BeeSeek uses Face ID to secure your transaction PIN.",
        "NSLocationWhenInUseUsageDescription": "BeeSeek needs your location to find service providers nearby.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": [
              "35F9.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": [
              "E174.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.beeseek.client",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/splash-icon-dark.png",
            "backgroundColor": "#031745"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAllowPermissionDescription": "BeeSeek needs your location to help you find service providers nearby.",
          "locationWhenInUsePermissionDescription": "BeeSeek needs your location to help you find service providers nearby.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "BeeSeek needs access to your photos so you can upload profile pictures, support tickets, and chat attachments.",
          "cameraPermission": "BeeSeek needs access to your camera so you can take photos for your profile and communications."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#031745",
          "sounds": []
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "BeeSeek needs access to your microphone to record voice messages in chat."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "BeeSeek uses Face ID to secure your transaction PIN and account access."
        }
      ],
      "@sentry/react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "24a7decf-8ba3-4d0b-ae45-ece17952bfde"
      },
      "router": {}
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/24a7decf-8ba3-4d0b-ae45-ece17952bfde"
    },
    "owner": "it_nova"
  }
}
